OPENAI_API_KEY=

ASTRA_DB_SECURE_BUNDLE_PATH=
ASTRA_DB_APPLICATION_TOKEN=
ASTRA_DB_KEYSPACE=

# Web app authentication (NextAuth)
# For local development use http://localhost:3000
# For Vercel deployments set this to your deployment URL, e.g. https://your-app.vercel.app
# Vercel also exposes NEXTAUTH_URL automatically via the VERCEL_URL env var;
# if NEXTAUTH_URL is left blank NextAuth will fall back to VERCEL_URL on Vercel.
NEXTAUTH_URL=http://localhost:3000
# Generate a strong secret with: openssl rand -base64 32
NEXTAUTH_SECRET=
APP_AUTH_EMAIL=
APP_AUTH_PASSWORD=
APP_AUTH_NAME=AviationRAG User

# Python executable used by the API bridge (defaults to "python")
# On a self-hosted server you may need to set this to "python3" or an absolute path.
# Note: the Python bridge is not supported on Vercel's serverless runtime.
# When deploying to Vercel, the /api/chat/* routes require a self-hosted server
# or a separate Python service reachable via HTTP.
PYTHON_EXECUTABLE=python
